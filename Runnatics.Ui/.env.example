# Copy to .env.development.local and fill in real values. Never commit secrets.

# Public API base URL (leave empty in local dev if using a dev-server proxy)
VITE_PUBLIC_API_URL=

# API base URL used by legacy service helpers
VITE_API_BASE_URL=https://your-api.azurewebsites.net/api

# Shared key for client-side encryption (must match backend Encryption:Key)
VITE_ENCRYPTION_KEY=your_encryption_key_here

# Shared key validated by the backend on every public API request
VITE_PUBLIC_API_KEY=your_public_api_key_here
